# ============================================================
# LocalMuse V2 - .gitignore
# ============================================================

# --- Python virtual environment (generated by setup.bat) ---
venv/
venv_old_DELETE_ME/

# --- Portable Python runtime (generated by build_portable_python.bat) ---
python/

# --- Python runtime artifacts ---
__pycache__/
*.pyc
*.pyo

# --- LocalMuse runtime artifacts ---
localmuse_crash.log
*.log

# --- Index / library data (user-specific, can be large) ---
# Adjust these if your index store lives elsewhere - see
# src/infra/index_store.py and LOCALMUSE_MODIFICATION_GUIDE.md
*.index
*.faiss
data/
indexes/

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Packaging scratch ---
*.7z
*.zip
